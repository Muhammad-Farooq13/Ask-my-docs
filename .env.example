# LLM Provider ("openai" or "ollama")
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (if using local, free LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embedding model (HuggingFace — runs locally, no API key needed)
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_BATCH_SIZE=64

# Reranker model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# Retrieval settings
BM25_TOP_K=20
VECTOR_TOP_K=20
HYBRID_TOP_K=10
RRF_K=60

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Storage paths
DATA_DIR=data
VECTOR_STORE_PATH=data/processed/faiss_index
BM25_STORE_PATH=data/processed/bm25_store.pkl

# API
API_HOST=0.0.0.0
API_PORT=8000
# Set to a secret string to require "Authorization: Bearer <key>" on write endpoints.
# Leave empty to disable auth (local dev only).
API_KEY=
# Comma-separated allowed CORS origins.  Use "*" only in development.
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
# Restrict ingestion to this directory (path traversal guard).
ALLOWED_INGEST_DIR=data
# Set to "json" in production for structured log ingestion (e.g. Datadog, CloudWatch).
LOG_FORMAT=text

# Evaluation thresholds (0.0–1.0)
EVAL_FAITHFULNESS_THRESHOLD=0.7
EVAL_RELEVANCE_THRESHOLD=0.7
EVAL_CITATION_THRESHOLD=0.8
EVAL_DATASET_PATH=data/eval/golden_dataset.jsonl
